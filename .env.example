# Copy to .env and fill values
DB_HOST=127.0.0.1
DB_NAME=edusync_mu
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Site settings
SITE_NAME=EduSync MU
SITE_URL=http://localhost:8000

# Base path for subdirectory deployments.
# Leave empty if the project is at the web root (e.g., localhost:8000).
# Set to your folder name if using XAMPP htdocs (e.g., /edusync).
BASE_PATH=

# AI API Keys
GEMINI_API_KEY=
HF_API_KEY=
